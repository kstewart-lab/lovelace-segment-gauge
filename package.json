{
  "name": "segment-gauge",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "harness:dev": "vite --config dev-harness/vite.config.ts",
    "harness:build": "vite build --config dev-harness/vite.config.ts",
    "harness:preview": "vite preview --config dev-harness/vite.config.ts",
    "docs:generate": "node scripts/generate-configuration-docs.mjs",
    "docs:check": "npm run docs:generate && git diff --exit-code -- docs/configuration.md",
    "arch:check": "node scripts/architecture/check.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "lit": "^3.1.3"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
